SECRET_KEY=

# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIVATE:', v.private_pem().decode()); print('PUBLIC:', v.public_key.public_bytes_raw())"
# Or use: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:you@example.com

# Optional — enables Telegram as a secondary notification channel
TELEGRAM_TOKEN=
TELEGRAM_BOT_USERNAME=
